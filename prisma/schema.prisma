// ==================== AETHER POS SCHEMA ====================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== OUTLET GROUP (Multi-Outlet) ====================
model OutletGroup {
  id        String   @id @default(cuid())
  name      String                        // Business name: "RNB"
  ownerId   String   @unique                   // Main account owner (User id)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User     @relation("GroupOwner", fields: [ownerId], references: [id])
  outlets Outlet[]
  transfers OutletTransfer[]
}

// ==================== OUTLET ====================
model Outlet {
  id           String   @id @default(cuid())
  name         String
  address      String?
  phone        String?
  accountType  String   @default("free") // free, pro, enterprise
  isMain       Boolean  @default(false)  // Main/headquarters outlet in the group
  groupId      String?                      // Belongs to an outlet group (null = standalone)
  planExpiresAt DateTime?                   // When the current paid plan expires (null = free/never expires)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  group            OutletGroup?       @relation(fields: [groupId], references: [id])
  users            User[]
  products         Product[]
  customers        Customer[]
  categories       Category[]
  transactions     Transaction[]
  auditLogs        AuditLog[]
  setting          OutletSetting?
  promos           Promo[]
  crewPermissions  CrewPermission[]
  productVariants  ProductVariant[]
  transferItems    TransferItem[]
  transfersFrom    OutletTransfer[] @relation("TransferFrom")
  transfersTo      OutletTransfer[] @relation("TransferTo")
  suppliers        Supplier[]
  inventoryItems   InventoryItem[]
  inventoryCategories InventoryCategory[]
  purchaseOrders   PurchaseOrder[]
  purchaseOrderItems PurchaseOrderItem[]
  inventoryMovements    InventoryMovement[]
  inventoryTransferItems InventoryTransferItem[]
}

// ==================== USER ====================
model User {
  id            String   @id @default(cuid())
  name          String
  email         String
  password      String
  role          String   @default("CREW") // OWNER or CREW
  outletId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  outlet          Outlet           @relation(fields: [outletId], references: [id])
  transactions    Transaction[]
  auditLogs       AuditLog[]
  crewPermission  CrewPermission?
  ownedGroup      OutletGroup?     @relation("GroupOwner")
  transfersCreated  OutletTransfer[] @relation("TransferCreator")
  transfersReceived OutletTransfer[] @relation("TransferReceiver")
  purchaseOrders    PurchaseOrder[]
  inventoryMovements InventoryMovement[] @relation("MovementUser")

  @@unique([email, outletId])
}

// ==================== CATEGORY ====================
model Category {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("zinc")  // Tailwind color name for chip styling
  outletId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outlet   Outlet     @relation(fields: [outletId], references: [id])
  products Product[]
  promos   Promo[]

  @@unique([name, outletId])
}

// ==================== PRODUCT ====================
model Product {
  id            String   @id @default(cuid())
  name          String
  sku           String?
  barcode       String?
  hpp           Float    @default(0)    // Harga Pokok Produksi (Cost Price)
  price         Float                    // Selling Price
  bruto         Float    @default(0)    // Gross weight
  netto         Float    @default(0)    // Net weight
  stock         Int      @default(0)    // Current stock
  lowStockAlert Int      @default(10)   // Alert threshold
  unit          String   @default("pcs") // Unit: pcs, ml, lt, gr, kg, box, etc.
  image         String?                 // Snapshot image URL
  categoryId    String?
  outletId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hasVariants      Boolean        @default(false) // Has product variants
  hasComposition   Boolean        @default(false) // Uses inventory composition (BOM/recipe)
  outlet           Outlet           @relation(fields: [outletId], references: [id])
  category        Category?        @relation(fields: [categoryId], references: [id])
  transactionItems TransactionItem[]
  variants         ProductVariant[]
  compositions     ProductComposition[]

  @@unique([name, outletId])
}

// ==================== PRODUCT VARIANT ====================
model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  name      String                       // e.g. "Small", "Medium", "Large", "Original", "Matcha"
  sku       String?                      // Variant-specific SKU
  barcode   String?
  hpp       Float    @default(0)          // Cost price for this variant (auto from composition or manual)
  price     Float                        // Selling price for this variant
  stock     Int      @default(0)          // Independent stock per variant
  outletId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product          Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  outlet           Outlet               @relation(fields: [outletId], references: [id])
  transactionItems TransactionItem[]
  compositions     ProductComposition[] // Per-variant BOM / recipe

  @@unique([name, productId])
}

// ==================== CUSTOMER ====================
model Customer {
  id          String   @id @default(cuid())
  name        String
  whatsapp    String               // WhatsApp number
  totalSpend  Float    @default(0) // Running total
  points      Int      @default(0) // Current loyalty points
  outletId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  outlet       Outlet       @relation(fields: [outletId], references: [id])
  transactions Transaction[]
  loyaltyLogs  LoyaltyLog[]

  @@unique([whatsapp, outletId])
}

// ==================== TRANSACTION ====================
model Transaction {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  subtotal      Float
  discount      Float    @default(0)
  pointsUsed    Int      @default(0)
  taxAmount     Float    @default(0)    // PPN / tax amount
  total         Float
  paymentMethod String               // CASH, QRIS, DEBIT
  paidAmount    Float    @default(0)
  change        Float    @default(0)
  note          String?
  outletId      String
  customerId    String?
  userId        String
  createdAt     DateTime @default(now())

  outlet           Outlet            @relation(fields: [outletId], references: [id])
  customer         Customer?         @relation(fields: [customerId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  items            TransactionItem[]
  loyaltyLogs      LoyaltyLog[]
  consumptionSnapshots TransactionConsumption[]
}

// ==================== TRANSACTION ITEM ====================
model TransactionItem {
  id             String      @id @default(cuid())
  productId      String?
  variantId      String?
  productName    String
  productSku     String?                          // Snapshot: product SKU at time of sale
  variantName    String?
  variantSku     String?                          // Snapshot: variant SKU at time of sale
  price          Float
  qty            Int
  subtotal       Float
  itemDiscount   Float       @default(0)  // Manual per-item discount amount (nominal Rp)
  hpp            Float
  transactionId  String

  product     Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  transaction Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

// ==================== TRANSACTION CONSUMPTION (Snapshot) ====================
// Snapshots inventory consumption at checkout time so that void can restore
// exactly what was consumed — even if the product recipe/composition
// was changed months after the original sale.
//
// Aggregated per inventory item per transaction (not per TransactionItem).
// One transaction may consume 3000g coffee from 3 different cart items → 1 row here.
model TransactionConsumption {
  id               String   @id @default(cuid())
  transactionId    String
  inventoryItemId  String
  itemName         String               // Snapshot: inventory item name at checkout
  baseUnit         String               // Snapshot: "kg", "gr", "ml", etc.
  quantityUsed     Float                // Total consumed in base units (e.g. 2.5 kg)
  sourceDetails    String               // JSON: [{productName, variantName?, qty, batches}] for audit trail
  createdAt        DateTime @default(now())

  transaction    Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  inventoryItem  InventoryItem  @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
}

// ==================== LOYALTY LOG ====================
model LoyaltyLog {
  id             String    @id @default(cuid())
  type           String              // EARN or REDEEM
  points         Int                 // positive for earn, negative for redeem
  description    String
  customerId     String
  transactionId  String?
  createdAt      DateTime @default(now())

  customer    Customer    @relation(fields: [customerId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])
}

// ==================== AUDIT LOG ====================
model AuditLog {
  id          String   @id @default(cuid())
  action      String               // CREATE, RESTOCK, SALE, ADJUSTMENT, UPDATE
  entityType  String               // PRODUCT, STOCK, OUTLET, SETTINGS, TRANSACTION
  entityId    String?              // ID of the referenced entity (any type)
  details     String?              // JSON string with change details
  outletId    String
  userId      String
  createdAt   DateTime @default(now())

  outlet  Outlet  @relation(fields: [outletId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

// ==================== OUTLET SETTING ====================
model OutletSetting {
  id      String @id @default(cuid())
  outletId String @unique

  // Payment methods: comma-separated enabled methods
  paymentMethods String @default("CASH,QRIS")

  // Loyalty program config
  loyaltyEnabled          Boolean @default(true)
  loyaltyPointsPerAmount  Int     @default(10000) // 1 point per Rp10,000 spent
  loyaltyPointValue       Int     @default(100)   // 1 point = Rp100 discount

  // Receipt config
  receiptBusinessName String @default("Aether POS")
  receiptAddress      String @default("")
  receiptPhone        String @default("")
  receiptFooter       String @default("Terima kasih atas kunjungan Anda!")
  receiptLogo         String @default("")

  // PPN / Tax
  ppnEnabled      Boolean @default(false)  // Enable PPN tax
  ppnRate         Float   @default(11)     // PPN percentage (default 11% for Indonesia)

  // Manual per-item discount toggle for POS Terminal
  manualDiscountEnabled Boolean @default(false) // Enable/disable manual discount per item in cart

  // Double receipt print settings
  receiptDoublePrintEnabled Boolean @default(false)  // Enable double receipt printing
  receiptMerchantCopyEnabled Boolean @default(true)   // Print merchant copy
  receiptCustomerCopyEnabled Boolean @default(true)   // Print customer copy
  receiptBatchOrderEnabled Boolean @default(false)    // Enable batch order copy

  // Theme
  themePrimaryColor String @default("emerald") // tailwind color name: emerald, blue, violet, rose, amber

  // Telegram notifications
  telegramBotToken  String?                // Telegram Bot Token (from @BotFather)
  telegramChatId   String?                // Owner's Telegram chat ID for notifications
  notifyOnTransaction Boolean @default(true) // Notify on every new transaction
  notifyOnCustomer   Boolean @default(true) // Notify on new customer registration
  notifyDailyReport  Boolean @default(true) // Daily revenue summary
  notifyWeeklyReport Boolean @default(false) // Weekly report
  notifyMonthlyReport Boolean @default(true) // Monthly report
  notifyOnInsight     Boolean @default(true) // Business insight notifications (critical/high priority)

  outlet    Outlet   @relation(fields: [outletId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== PROMO ====================
model Promo {
  id          String   @id @default(cuid())
  name        String
  type        String               // "PERCENTAGE", "NOMINAL", or "BUY_X_GET_DISCOUNT"
  value       Float                // percentage (e.g. 10) or nominal (e.g. 50000)
  minPurchase Float?               // minimum purchase amount to apply
  maxDiscount Float?               // max discount cap for percentage type
  active      Boolean  @default(true)
  outletId    String
  // For BUY_X_GET_DISCOUNT: minimum qty of items to qualify
  buyMinQty   Int      @default(0)
  // For BUY_X_GET_DISCOUNT: "PERCENTAGE" or "NOMINAL" — how the discount is calculated
  discountType String  @default("PERCENTAGE")
  categoryId  String?               // null = all categories, specific ID = category-only
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  outlet   Outlet   @relation(fields: [outletId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

// ==================== CREW PERMISSION ====================
model CrewPermission {
  id       String @id @default(cuid())
  userId   String @unique
  // Comma-separated allowed pages for this crew member
  pages    String @default("pos")
  outletId String

  user   User   @relation(fields: [userId], references: [id])
  outlet Outlet @relation(fields: [outletId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== PLAN ====================
model Plan {
  id          String   @id @default(cuid())
  name        String                        // Display name: "Free", "Pro", "Enterprise"
  slug        String   @unique               // URL-safe key: "free", "pro", "enterprise"
  price       Float    @default(0)           // Price in IDR (0 = free)
  duration    Int      @default(1)           // Duration in months (1 = per bulan, 12 = per tahun)
  paymentLink String?                       // External payment URL for upgrade
  features    String   @default("{}")       // JSON: feature key-value pairs (booleans & numbers)
  active      Boolean  @default(true)       // Show/enable this plan
  sortOrder   Int      @default(0)          // Display order (lower = first)
  description String?                       // Short tagline
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== OUTLET TRANSFER (Surat Jalan) ====================
model OutletTransfer {
  id             String   @id @default(cuid())
  transferNumber String   @unique            // Auto-generated: TRF-YYYYMMDD-XXXX or TRF-INV-YYYYMMDD-XXXX
  fromOutletId   String                       // Source outlet (outbound)
  toOutletId     String                       // Destination outlet (inbound)
  itemType       String   @default("PRODUCT") // PRODUCT = finished goods, INVENTORY = raw materials (bahan baku)
  status         String   @default("DRAFT")  // DRAFT, IN_TRANSIT, RECEIVED, CANCELLED
  notes          String?                      // Notes / keterangan
  receivedById   String?                      // User who received (at destination)
  receivedAt     DateTime?                    // When received at destination
  createdById    String                       // User who created the transfer
  outletId       String                       // For audit trail (source outlet)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  fromOutlet   Outlet            @relation("TransferFrom", fields: [fromOutletId], references: [id])
  toOutlet     Outlet            @relation("TransferTo", fields: [toOutletId], references: [id])
  group        OutletGroup?      @relation(fields: [groupId], references: [id])
  groupId      String?           // Which group this transfer belongs to
  createdBy    User              @relation("TransferCreator", fields: [createdById], references: [id])
  receivedBy   User?             @relation("TransferReceiver", fields: [receivedById], references: [id])
  items        TransferItem[]
  inventoryTransferItems InventoryTransferItem[]

  // SQLite indexes removed for compatibility
}

// ==================== TRANSFER ITEM ====================
model TransferItem {
  id              String   @id @default(cuid())
  transferId      String
  productName     String                       // Snapshot: product name at time of transfer
  productSku      String?                      // Snapshot: SKU
  productBarcode  String?                      // Snapshot: barcode
  quantity        Int                          // Quantity transferred
  hpp             Float    @default(0)          // Cost price snapshot
  price           Float                        // Selling price snapshot
  productSnapshot String?                      // JSON: full product data (image, unit, category, variants, etc.)
  outletId        String                       // Source outlet (for audit)
  createdAt       DateTime @default(now())

  transfer OutletTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  outlet   Outlet          @relation(fields: [outletId], references: [id])

  // SQLite indexes removed for compatibility
}

// ==================== SUPPLIER ====================
model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  notes     String?
  outletId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outlet    Outlet          @relation(fields: [outletId], references: [id], onDelete: Cascade)
  purchases PurchaseOrder[]
}

// ==================== INVENTORY CATEGORY ====================
model InventoryCategory {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("zinc") // Tailwind color name
  outletId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outlet Outlet          @relation(fields: [outletId], references: [id], onDelete: Cascade)
  items  InventoryItem[]

  @@unique([name, outletId])
}

// ==================== INVENTORY ITEM (Raw Material) ====================
model InventoryItem {
  id            String   @id @default(cuid())
  name          String
  sku           String?
  baseUnit      String                      // Always tracked in base unit: gr, ml, kg, liter, meter, pcs
  stock         Float    @default(0)          // Current stock in base units (Float for precision)
  avgCost       Float    @default(0)          // Weighted average cost per base unit
  lowStockAlert Float    @default(0)
  status        String   @default("ACTIVE")   // ACTIVE, ARCHIVED — lifecycle: CREATE → ACTIVE → ARCHIVED
  outletId      String
  categoryId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([name, outletId])

  outlet         Outlet              @relation(fields: [outletId], references: [id], onDelete: Cascade)
  category       InventoryCategory?  @relation(fields: [categoryId], references: [id])
  purchaseItems  PurchaseOrderItem[]
  compositions   ProductComposition[]
  movements      InventoryMovement[]
  inventoryTransferItems InventoryTransferItem[]
  consumptionSnapshots    TransactionConsumption[]
}

// ==================== PURCHASE ORDER ====================
model PurchaseOrder {
  id          String   @id @default(cuid())
  orderNumber String   @unique            // Auto-generated: PO-YYYYMMDD-XXXX
  supplierId  String?
  totalCost   Float    @default(0)
  notes       String?
  outletId    String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  outlet    Outlet             @relation(fields: [outletId], references: [id], onDelete: Cascade)
  createdBy  User               @relation(fields: [userId], references: [id])
  supplier  Supplier?          @relation(fields: [supplierId], references: [id])
  items     PurchaseOrderItem[]
}

// ==================== PURCHASE ORDER ITEM ====================
model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  inventoryItemId String
  name            String                       // Snapshot of inventory item name
  purchaseQty     Float                        // Qty in purchase unit (e.g. 1 Ekor)
  purchaseUnit    String                       // Display unit (e.g. "Ekor", "Jerigen", "Roll")
  baseQty         Float                        // Converted to base unit (e.g. 1.85 kg)
  baseUnit        String                       // Base unit (e.g. "kg", "ml")
  unitCost        Float                        // Cost per base unit
  totalCost       Float                        // baseQty * unitCost
  outletId        String                       // For audit trail

  purchaseOrder  PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem  InventoryItem  @relation(fields: [inventoryItemId], references: [id])
  outlet         Outlet         @relation(fields: [outletId], references: [id])
}

// ==================== PRODUCT COMPOSITION (Recipe / BOM) ====================
// yieldPerBatch: How many output units one "batch" of this composition produces.
//   qty = bahan per 1 batch, yieldPerBatch = hasil per 1 batch.
//   Contoh: 1kg kopi → 55 cup  →  qty=1, baseUnit="kg", yieldPerBatch=55
//   Default 1 = setiap 1 unit produk butuh `qty` bahan (behavior lama).
model ProductComposition {
  id              String   @id @default(cuid())
  productId       String
  variantId       String?                      // Per-variant composition (null = product-level for non-variant products)
  inventoryItemId String
  qty             Float    @default(0)          // Quantity consumed per 1 batch (in base unit)
  yieldPerBatch   Float    @default(1)          // How many product units 1 batch produces (default 1 = legacy mode)
  baseUnit        String                       // Base unit of the inventory item
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
}

// ==================== INVENTORY MOVEMENT (Log Pergerakan Stok Bahan) ====================
model InventoryMovement {
  id             String   @id @default(cuid())
  type           String                       // RESTOCK, ADJUSTMENT, CONSUMPTION, TRANSFER_OUT, TRANSFER_IN, PURCHASE
  quantity       Float                        // Positive for stock in, negative for stock out
  previousStock  Float                        // Stock before movement
  newStock       Float                        // Stock after movement
  referenceId    String?                      // ID of related record (transferId, purchaseOrderId, etc.)
  referenceType  String?                      // TRANSFER, PURCHASE_ORDER, ADJUSTMENT, CONSUMPTION
  notes          String?                      // Additional notes
  outletId       String
  inventoryItemId String
  userId         String?                      // User who triggered the movement
  createdAt      DateTime @default(now())

  outlet          Outlet          @relation(fields: [outletId], references: [id])
  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  user            User?           @relation("MovementUser", fields: [userId], references: [id])
}

// ==================== INVENTORY TRANSFER ITEM (Bahan Baku Transfer) ====================
model InventoryTransferItem {
  id               String   @id @default(cuid())
  transferId       String
  inventoryItemId  String                       // Reference to InventoryItem (bahan baku)
  itemName         String                       // Snapshot: item name at time of transfer
  itemSku          String?                      // Snapshot: SKU
  baseUnit         String                       // Snapshot: base unit (kg, gr, ml, etc.)
  quantity         Float                        // Quantity transferred (in base units)
  avgCost          Float    @default(0)         // Cost snapshot
  outletId         String                       // Source outlet (for audit)
  createdAt        DateTime @default(now())

  transfer       OutletTransfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  inventoryItem  InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  outlet         Outlet          @relation(fields: [outletId], references: [id])
}